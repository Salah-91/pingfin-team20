# ─── PingFin Bank — .env voorbeeld ──────────────────────────────────────────
# Kopieer naar .env en pas aan PER bank-instance (Bank1 = b1, Bank2 = b2).

# Bank-identiteit
BIC=CEKVBE88
BANK_NAME=PingFin Bank Team 20 — Bank1
PORT=3000

# Database (Railway: gebruik Railway-vars; lokaal docker: host=db)
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASS=pingfin_dev_password
DB_NAME=pingfin_b1

# Clearing Bank
CB_URL=https://stevenop.be/pingfin/api/v2
CB_SECRET=                      # PER BIC, GEHEIM — geleverd door coach (Steven)
CB_TOKEN=                       # optioneel; leeg laten = auto-fetch via secret_key
CB_POLL_MS=30000

# Bearer-token dat WIJ verwachten op POST /api/po_in en /api/ack_in.
# Andere banken/CB moeten dit token meesturen om iets bij ons in te dienen.
INCOMING_TOKEN=changeme-bank1-incoming

# Achtergrondjobs (poller + timeout)
JOBS_ENABLED=true
OUTSTANDING_TIMEOUT_MS=3600000

# Teamleden voor /api/info (JSON-array string)
TEAM_MEMBERS=[{"name":"Salaheddine Sennouni","role":"Developer"},{"name":"Abdallah Azouagh","role":"Team Lead"},{"name":"Ayoub Abdeddoun","role":"Analyst"},{"name":"Marwan Saidi","role":"Developer"}]
